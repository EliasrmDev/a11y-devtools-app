# ────────────────────────────────────────────────────────────────────────────
# a11y-devtools-api — environment variables reference
#
# Copy this file to `.dev.vars` (for `wrangler dev`) or set secrets via
# `wrangler secret put <NAME>` for production deployments.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string (HTTP-compatible driver).
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/a11y_db?sslmode=require

# ── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM Key Encryption Key (KEK) — 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32
# NEVER reuse across environments. Rotate using the KEK rotation job.
KEK_CURRENT=<base64-encoded-32-byte-key>

# KEK version integer — increment on rotation (e.g. 1, 2, 3).
# Existing secrets use their stored version; new secrets use this version.
KEK_VERSION=1

# ── Auth provider ────────────────────────────────────────────────────────────
# Which external auth provider issues tokens.
# Allowed values: clerk | better-auth
AUTH_PROVIDER=clerk

# Clerk publishable key (used to validate JWTs issued by Clerk).
# Only required when AUTH_PROVIDER=clerk.
CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk secret key (used to verify Clerk session tokens server-side).
# Only required when AUTH_PROVIDER=clerk.
CLERK_SECRET_KEY=sk_live_...

# better-auth secret — used to sign/verify JWTs when AUTH_PROVIDER=better-auth.
# Generate with: openssl rand -base64 32
# Only required when AUTH_PROVIDER=better-auth.
JWT_SECRET=<base64-encoded-secret>

# ── Email ────────────────────────────────────────────────────────────────────
# Resend API key for transactional emails (deletion confirmation, reminders).
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Observability ────────────────────────────────────────────────────────────
# Better Stack (Logtail) source token.
# Logs are shipped via Cloudflare Workers Logpush → Better Stack HTTP drain.
# Set this in the Logpush destination, NOT as a Worker env var.
# Provided here for reference / local drain testing only.
LOGTAIL_SOURCE_TOKEN=<better-stack-source-token>

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the CORS middleware.
# Example: https://app.example.com,chrome-extension://abc123
ALLOWED_ORIGINS=chrome-extension://<extension-id>

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set automatically by wrangler.toml — do not set manually for production.
ENVIRONMENT=development
